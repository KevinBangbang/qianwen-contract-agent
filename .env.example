# 阿里云百炼平台 API Key
# 获取方式：访问 https://bailian.console.aliyun.com -> 密钥管理 -> 创建API Key
DASHSCOPE_API_KEY=sk-xxx

# DashScope API 地址（根据账号地域选择）
# 北京地域: https://dashscope.aliyuncs.com/compatible-mode/v1
# 美国弗吉尼亚: https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# 模型运行模式：cloud（云端API）或 local（本地部署）
MODEL_MODE=cloud

# 云端模型配置（通过DashScope调用）
CLOUD_MODEL=qwen-plus
CLOUD_VL_MODEL=qwen-vl-plus
CLOUD_EMBEDDING=text-embedding-v3

# 本地模型配置（Ollama或vLLM）
LOCAL_MODEL_SERVER=http://localhost:11434/v1
LOCAL_MODEL=qwen3-7b
